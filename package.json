{
  "name": "kanken-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rescript build && next dev --turbopack",
    "res:build": "rescript build",
    "res:watch": "rescript build -w",
    "res:clean": "rescript clean",
    "build": "rescript build && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "test": "rescript build && vitest",
    "test:ui": "rescript build && vitest --ui",
    "coverage": "rescript build && vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lhci": "lhci autorun",
    "lhci:mobile": "lhci autorun --preset=mobile",
    "lhci:desktop": "lhci autorun --preset=desktop"
  },
  "dependencies": {
    "@next/font": "^14.2.15",
    "next": "15.5.9",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@lhci/cli": "^0.15.0",
    "@rescript/core": "^1.6.1",
    "@rescript/react": "^0.15.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9",
    "eslint-config-next": "15.5.9",
    "jsdom": "^27.0.0",
    "rescript": "^12.3.0",
    "tailwindcss": "^4",
    "three": "^0.182.0",
    "typescript": "^5",
    "vitest": "^3.2.3"
  }
}
